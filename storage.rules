rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAllowedImageUpload() {
      return request.resource != null
          && request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');
    }

    function isAllowedUserFile(path) {
      // Hiện app chỉ upload avatar_*.jpg và qr_*.png
      return path.matches('avatar_.*\\.jpg') || path.matches('qr_.*\\.png');
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isAllowedUserFile(allPaths) && isAllowedImageUpload();
      allow delete: if isOwner(userId);
    }
  }
}
