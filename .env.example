# VoiceBill - Cấu hình client (KHÔNG chứa secret)
# Copy file này thành assets/.env
#
# Secret (Gemini API key) KHÔNG để ở đây. Nó được nạp vào Cloud Functions
# bằng lệnh:  firebase functions:secrets:set GEMINI_API_KEY

# Google Sign-In Web Client ID (chỉ cần cho Web - là public ID, không bí mật)
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here
